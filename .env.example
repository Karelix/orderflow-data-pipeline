# Copy this file to .env and fill in your real Hugging Face tokens.
# Never commit .env.

# Optional fallback token used when a repo does not define token_env_var.
HF_TOKEN=

# Token for your-username/orderflow-es-001.
HF_TOKEN_ORDERFLOW_ES_001=

# Token for other-username/orderflow-es-002.
HF_TOKEN_ORDERFLOW_ES_002=
